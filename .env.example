# Browser-safe Supabase configuration. These are identifiers, not privileged secrets.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<from-supabase-status-or-hosted-dashboard>
# Optional avatar-upload override; defaults to {NEXT_PUBLIC_SUPABASE_URL}/storage/v1/upload/resumable.
NEXT_PUBLIC_SUPABASE_STORAGE_TUS_URL=http://127.0.0.1:54321/storage/v1/upload/resumable
# Server/operator-only access for local fixtures and avatar/retention operations. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=<local-or-hosted-service-role-key>
SITE_URL=http://127.0.0.1:3000
# Local/CI only. Never enable in production.
ENABLE_TEST_AUTH=false
# Only when ENABLE_TEST_AUTH=true in local/CI environments:
# TEST_AUTH_EMAIL=jam-session-e2e@example.test
# TEST_AUTH_PASSWORD=<ephemeral local password>
