# Browser-safe Supabase configuration. These are identifiers, not privileged secrets.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<provided by the later local Auth setup>
SITE_URL=http://127.0.0.1:3000
# Local/CI only. Never enable in production.
ENABLE_TEST_AUTH=false
# Development or Vercel Preview only. The route also requires an authenticated, completed profile.
ENABLE_STUDIO_SPIKE=false
# Only when ENABLE_TEST_AUTH=true in local/CI environments:
# TEST_AUTH_EMAIL=jam-session-e2e@example.test
# TEST_AUTH_PASSWORD=<ephemeral local password>
