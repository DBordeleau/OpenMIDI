{
  "name": "jam-session",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:start": "supabase db start",
    "supabase:start:auth": "supabase start -x realtime,storage-api,imgproxy,studio,edge-runtime,logflare,vector,supavisor,mailpit,postgres-meta",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --local --level warning --fail-on warning",
    "db:test": "supabase test db",
    "db:types": "node scripts/generate-database-types.mjs --write",
    "db:types:check": "node scripts/generate-database-types.mjs --check",
    "auth:e2e:setup": "node scripts/setup-auth-e2e.mjs",
    "db:check": "npm run db:lint && npm run db:test && npm run db:types:check",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@dnd-kit/react": "0.3.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.109.0",
    "@waveform-playlist/browser": "15.3.4",
    "@waveform-playlist/playout": "12.5.4",
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "styled-components": "6.4.3",
    "tone": "15.1.22",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.18",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.18"
    }
  }
}
